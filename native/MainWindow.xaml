<Window x:Class="SimRekcahNative.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rekcah Industrial Lab" WindowStyle="None" WindowState="Maximized"
        Background="#000" Foreground="White"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="GlassBorder" TargetType="Border">
            <Setter Property="Background" Value="#AA0f172a"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" Color="Black" Opacity="0.5" ShadowDepth="0"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#EE1e293b"/>
            <Setter Property="BorderBrush" Value="#38bdf8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <!-- Background Layer: Unreal Engine Rendered Table -->
        <Image Source="Assets/Table.png" Stretch="UniformToFill">
            <Image.Effect>
                <BlurEffect Radius="2"/>
            </Image.Effect>
        </Image>
        
        <!-- UI Layer -->
        <Grid Margin="40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="400"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left: High-End Scoreboard -->
            <StackPanel Grid.Column="0">
                <Border Style="{StaticResource GlassBorder}" Padding="20">
                    <StackPanel>
                        <TextBlock Text="INTELLIGENCE FORGE" FontSize="14" FontWeight="Bold" Foreground="#38bdf8" Margin="0,0,0,20"/>
                        <ItemsControl x:Name="ScoreList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,10">
                                        <TextBlock Text="{Binding Label}" FontSize="16"/>
                                        <TextBlock Text="{Binding Score}" HorizontalAlignment="Right" FontSize="16" FontWeight="Bold" Foreground="#fbbf24"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                
                <Border Style="{StaticResource GlassBorder}" Padding="20" Margin="0,20,0,0">
                    <StackPanel>
                        <TextBlock x:Name="RoundText" Text="ROUND 01" FontSize="24" FontWeight="Black" Margin="0,0,0,5"/>
                        <TextBlock x:Name="TurnText" Text="TURN 12" FontSize="12" Foreground="#94a3b8"/>
                    </StackPanel>
                </Border>
            </StackPanel>
            
            <!-- Center: Active Play Zone -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Deck and Discard (Centered) -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button x:Name="StockButton" Width="140" Height="200" Click="OnDrawStock" Background="Transparent" BorderThickness="0">
                        <Border CornerRadius="12" BorderBrush="#38bdf8" BorderThickness="2" Background="#1e293b">
                            <TextBlock Text="STOCK" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Foreground="#38bdf8"/>
                        </Border>
                    </Button>
                    <Button x:Name="DiscardButton" Width="140" Height="200" Click="OnDrawDiscard" Margin="30,0,0,0" Background="Transparent" BorderThickness="0">
                        <Border CornerRadius="12" BorderBrush="#ef4444" BorderThickness="2" Background="#1e293b">
                            <TextBlock x:Name="TopDiscardText" Text="K♥" FontSize="48" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
                        </Border>
                    </Button>
                </StackPanel>
                
                <!-- Player Hand (Bottom) -->
                <StackPanel Grid.Row="1">
                    <ItemsControl x:Name="HandList">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Click="OnCardClick" Tag="{Binding Id}" Background="Transparent" BorderThickness="0">
                                    <Border Style="{StaticResource CardStyle}" Width="100" Height="150">
                                        <Grid>
                                            <TextBlock Text="{Binding Rank}" Margin="10" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Suit}" FontSize="48" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
                        <Button x:Name="ShowBtn" Content="SHOW" Click="OnShow" Width="150" Height="50" Background="#10b981" Foreground="White" FontWeight="Bold"/>
                        <Button x:Name="DiscardBtn" Content="DISCARD" Click="OnDiscard" Width="150" Height="50" Background="#6366f1" Foreground="White" FontWeight="Bold" Margin="20,0,0,0"/>
                        <Button Content="EXIT" Click="OnExit" Width="100" Height="50" Background="#ef4444" Foreground="White" FontWeight="Bold" Margin="20,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
            
            <!-- Right: Industrial Log -->
            <Border Grid.Column="2" Style="{StaticResource GlassBorder}" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="TELEMETRY STREAM" FontSize="12" FontWeight="Bold" Foreground="#94a3b8" Margin="0,0,0,15"/>
                    <ListBox Grid.Row="1" x:Name="LogList" Background="Transparent" BorderThickness="0" Foreground="#cbd5e1" FontSize="12"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
